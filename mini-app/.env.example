# Базовый URL бэкенда. В DEV → http(s)://localhost:3001/api/v1.
# В прод-сборке должен быть HTTPS, иначе TG не подгрузит fetch-запросы.
VITE_API_BASE_URL=http://localhost:3001/api/v1

# Sentry DSN. Если пусто — Sentry не инициализируется (для DEV нормально).
VITE_SENTRY_DSN=

# Порт vite dev-сервера. По умолчанию 5173.
VITE_DEV_PORT=5173

# DEV-only: параметры мокового initData (когда открываем Mini App в обычном
# браузере без TG). Игнорируется в prod-сборке.
VITE_DEV_MOCK_USER_ID=99281932
VITE_DEV_MOCK_USERNAME=devuser
VITE_DEV_MOCK_START_PARAM=devstart
