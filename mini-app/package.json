{
  "name": "interstellar-mini-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Interstellar — Telegram Mini App (AI-чат с историческими личностями)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "analyze": "vite-bundle-visualizer"
  },
  "dependencies": {
    "@sentry/react": "^8.34.0",
    "@telegram-apps/sdk-react": "^3.3.9",
    "idb-keyval": "^6.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "eruda": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.10",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-mkcert": "^1.17.6"
  },
  "engines": {
    "node": ">=18"
  }
}
