# ─── polza.ai (LLM-провайдер) ─────────────────────────────────────────────
POLZA_API_KEY=                                    # обязательный
POLZA_API_URL=https://api.polza.ai/api/v1/chat/completions
# ВНИМАНИЕ: полное имя модели с namespace (vendor/model). Без префикса
# polza.ai вернёт 400 "model not found".
# Проверить актуальный каталог: curl https://api.polza.ai/api/v1/models \
#   -H "Authorization: Bearer $POLZA_API_KEY" | jq '.data[].id'
#
# Дефолт: openai/gpt-4o-mini ($0.15/$0.60 за 1M tokens, прекрасный русский,
# отличный character-play, поддерживает NSFW для острых персонажей).
# Альтернативы для оптимизации:
#   - openai/gpt-4.1-mini ($0.40/$1.60) — чуть умнее, та же family
#   - google/gemini-2.0-flash ($0.075/$0.30) — в 2 раза дешевле, но NSFW
#     блокируется safety-filters Google
POLZA_MODEL=openai/gpt-4o-mini

# ─── Сервер ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Доверяем proxy от Render/Cloudflare для real-ip из X-Forwarded-For.
# 1 = первый хоп. На локалке поставь 0 чтобы не доверять.
TRUST_PROXY_HOPS=1

# ─── Telegram Mini App ────────────────────────────────────────────────────
# Токен бота из @BotFather (формат "123456:AABBCC...").
# В DEV без токена — запускай с DEV_BYPASS_INITDATA=1 (см. ниже).
BOT_TOKEN=

# username бота без @ (для генерации ссылок и логирования).
BOT_USERNAME=InterstellarBot

# Путь к файлу SQLite. Создастся автоматически при старте.
# В Render free-tier — используй persistent disk: /var/data/interstellar.sqlite
DB_PATH=./data/interstellar.sqlite

# DEV-only: пропустить HMAC-валидацию initData. Полезно когда у тебя ещё
# нет реального BOT_TOKEN, но хочется потестить эндпоинты с моковым initData
# из mini-app/. На production ОБЯЗАТЕЛЬНО false/unset.
# Сервер ОТКАЖЕТСЯ стартовать если NODE_ENV=production И DEV_BYPASS_INITDATA=1.
DEV_BYPASS_INITDATA=0

# CORS allowlist для mini-app. Через запятую без пробелов.
# В DEV: https://localhost:5173
# В prod: https://your-mini-app.pages.dev
CORS_ALLOWED_ORIGINS=https://localhost:5173,http://localhost:5173

# ─── RBAC (Affiliate program) ─────────────────────────────────────────────
# Telegram user_id админов (через запятую без пробелов). Свой узнаешь
# через @userinfobot в Telegram. Минимум один админ обязателен для
# работы partner-кабинета (без админа никто не может выдать роль).
#
# Это ИММУТАБЕЛЬНЫЙ источник истины — admin-роль НИКОГДА не определяется
# из БД. Изменение списка → редеплой/restart.
ADMIN_TELEGRAM_IDS=

# AES-256 ключ для шифрования PII партнёров (ИНН, ФИО, реквизиты).
# Сгенерируй один раз и сохрани в надёжном менеджере паролей:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ⚠️ ПОТЕРЯ КЛЮЧА = ПОТЕРЯ ВСЕХ ДАННЫХ ПАРТНЁРОВ. Зашифрованные blob'ы
# невосстановимы без ключа.
PAYOUT_ENCRYPTION_KEY=

# Версия согласия на обработку ПД партнёров. При изменении содержимого
# юридического документа (privacy policy для партнёров) — поднимай число,
# партнёры получат запрос подтвердить новую версию.
PARTNER_PII_CONSENT_VERSION=2026.05

# ИНН нашего лица (юр. лица / ИП / самозанятого), на который партнёры будут
# выставлять чеки через "Мой налог". Отображается партнёру в кабинете при
# запросе выплаты.
BUSINESS_INN=
BUSINESS_NAME=

# ─── Платежи (Stars) — мультитарифная система ───────────────────────────
# Цены в Stars (XTR). Точка истины — backend/payments.js getPlanConfig().
#
# Структура тарифов (3-tier + Day Pass):
#   Free      — 10 сообщений LIFETIME (one-shot, anti-abuse, без месячного reset)
#   Basic     — 50 msg/день, без NSFW, без custom char limits
#   Premium   — 200 msg/день, NSFW доступен, длиннее история (30 msgs)
#   Day Pass  — 24h без daily-cap для активного платного юзера
#
# Стандартные цены май 2026 (на основе аналитики конкурентов и Stars→₽
# конверсии после Apple/Google и TG cuts ~0.68₽/Star net):
STAR_PRICE_BASIC=199             # ~300₽ для юзера, ~135₽ net нам, marja ~52%
STAR_PRICE_PREMIUM=499           # ~750₽ для юзера, ~340₽ net нам, marja ~25%
STAR_PRICE_DAY_PASS=50           # ~75₽ для юзера, ~34₽ net нам, 24h без лимита

# Legacy (для совместимости со старыми API-клиентами, если есть):
STAR_PRICE_MONTH=199

# Random secret_token для защиты webhook'а от подделок. Генери через:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Используется при setWebhook и проверяется на КАЖДОМ POST /telegram/webhook
# через заголовок X-Telegram-Bot-Api-Secret-Token (constant-time compare).
TELEGRAM_WEBHOOK_SECRET=

# Публичный URL бэка для setWebhook. В Render — твой *.onrender.com URL.
# В DEV — URL cloudflared/ngrok туннеля.
PUBLIC_BASE_URL=

# ─── Прокси для api.telegram.org (только если заблокирован РКН) ──────────
# Заполни ЕСЛИ:
#   curl https://api.telegram.org/bot<TOKEN>/getMe
# с твоего сервера возвращает таймаут / 000.
# Поддерживаемые форматы:
#   http://user:pass@proxy.example.com:8080
#   https://user:pass@proxy.example.com:443      (рекомендую)
#   socks5://user:pass@proxy.example.com:1080
TG_API_PROXY=

# Альтернатива прокси: запустить https://github.com/tdlib/telegram-bot-api
# рядом с нашим бэком (бесплатно, более стабильно при блокировках api.tg.org).
# После запуска — впишите URL вашего local-сервера:
TG_API_BASE_URL=

# ─── Reconciliation ───────────────────────────────────────────────────────
# Каждые N минут крон проходит invoices_outstanding и сверяется с
# getStarTransactions чтобы догнать потерянные webhook'и.
# По умолчанию каждые 5 мин (см. Plan agent's playbook).
RECONCILE_INTERVAL_MIN=5
